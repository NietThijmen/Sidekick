# Application
PUBLIC_APP_NAME="Sidekick"

# Drizzle
DATABASE_URL=file:local.db

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Atlassian OAuth
# https://www.better-auth.com/docs/authentication/atlassian
ATLASSIAN_CLIENT_ID=""
ATLASSIAN_CLIENT_SECRET=""

# Openrouter
OPENROUTER_API_KEY=""

# GitHub API token (optional, increases rate limits for GitHub tools)
GITHUB_TOKEN=""

# Atlassian cloud ID (optional, auto-detected from OAuth token if not set)
ATLASSIAN_CLOUD_ID=""

# Context7 SDK key for live documentation lookups (optional)
CONTEXT7_API_KEY=""

# Firecrawl API key for web scraping and search (optional; users can also add their own in profile)
FIRECRAWL_API_KEY=""

# Sentry (optional; users can also add their own in profile)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""